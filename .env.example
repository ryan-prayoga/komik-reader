ORIGIN=https://komik.ryanprayoga.dev
SUWAYOMI_URL=http://suwayomi:4567

# Auth (default: enabled)
AUTH_ENABLED=true
AUTH_SECRET=change-me-to-a-long-random-string
AUTH_DB_PATH=/app/data/auth.db
ALLOW_REGISTRATION=false
# Optional-auth: guests may browse/read without logging in.
# Server writes (library sync, categories, extensions, etc.) still need a session.
# /downloads is local-first (IndexedDB offline chapters) and stays guest-accessible.
# Default ON. Set false to force login on every page.
AUTH_ALLOW_GUEST=true

# Bootstrap admin (optional — first user can also register at /register)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_USERNAME=admin

# SMTP for forgot-password (set in server .env, not editable from admin UI)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Komik Reader <developer@ryanprayoga.dev>"